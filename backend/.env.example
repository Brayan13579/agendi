# ==============================
# WhatsApp Cloud API (Meta)
# ==============================
# Token que obtienes en developers.facebook.com
WHATSAPP_TOKEN=tu_token_aqui

# ID del número de teléfono de WhatsApp Business
WHATSAPP_PHONE_ID=tu_phone_id_aqui

# Token para verificar el webhook (tú lo inventas, puede ser cualquier texto)
WEBHOOK_VERIFY_TOKEN=barber_webhook_secret_123

# ==============================
# Firebase
# ==============================
# Ruta al archivo de credenciales que descargas desde Firebase Console
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json

# ==============================
# Servidor
# ==============================
PORT=3000

# ==============================
# Configuración del negocio
# ==============================
# Palabras que activan el bot (separadas por coma, sin espacios)
BOT_KEYWORDS=cita,agendar,reservar,turno,hora

# Minutos antes para enviar el recordatorio (por defecto 30)
REMINDER_MINUTES=30
